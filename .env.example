WATCH_DIR=/opt/research-inbox
STATE_DB=./state/research_bot.sqlite3
OUTPUT_DIR=./out
POLL_INTERVAL_MINUTES=15
PROCESS_LIMIT_PER_RUN=3
RECENT_MEMORY_LIMIT=20
BATCH_INSIGHTS_ENABLED=1
DIGEST_MODE=1
LOCAL_FILE_MIN_AGE_SECONDS=120
LOCAL_MAX_ITEMS=200
LOCAL_EXCLUDE_DIRS=ima-research-bot
LOCAL_LATEST_ONLY=1
IMA_MAX_PAGES=1
IMA_MAX_ITEMS=25
IMA_MAX_DOWNLOADS_PER_RUN=3
IMA_LATEST_DATE_FOLDER=1
IMA_LATEST_DATE_FOLDER_DEPTH=4
IMA_RECURSIVE=1

# OpenAI summarizer
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_DAILY_BUDGET_USD=5
OPENAI_TEXT_INPUT_USD_PER_1M=0.40
OPENAI_TEXT_OUTPUT_USD_PER_1M=1.60
OPENAI_TTS_USD_PER_1K_CHARS=0.03

# IMA / Tencent OpenAPI
# Use the Client ID + API Key from https://ima.qq.com/agent-interface
IMA_CLIENT_ID=
IMA_API_KEY=
IMA_BASE_URL=https://ima.qq.com
IMA_KNOWLEDGE_BASE_ID=

# AList / VPS source. Use this for full headless VPS ingestion from Quark via AList.
ALIST_BASE_URL=http://45.61.163.207:5244
ALIST_USERNAME=
ALIST_PASSWORD=
ALIST_TOKEN=
ALIST_PATH=/quark/来自：分享/【爱分享】盈策内外资(2)
ALIST_RECURSIVE=1
ALIST_MAX_ITEMS=200
ALIST_MAX_DOWNLOADS_PER_RUN=200
ALIST_MAX_PAGES=20
ALIST_TARGET_DAYS_AGO=
ALIST_TARGET_REPORT_DATE=
ALIST_TARGET_UTC_OFFSET_HOURS=8
ALIST_LATEST_ONLY=1
ALIST_RECENT_DAYS=7
ALIST_MIN_REPORT_DATE=

# Metadata-only radar. Does not download/open files.
RADAR_QUERIES=每日复盘,AI,半导体,电力,地产,钢铁,机器人,算力,PCB,高盛,花旗,摩根
RADAR_LIMIT_PER_QUERY=8

# ElevenLabs TTS. The app sends generated summaries to the ElevenLabs
# text-to-speech API and stores the returned MP3 under OUTPUT_DIR.
TTS_PROVIDER=openai
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SEND_TEXT_UPDATES=1

# WeCom / WeChat Work group robot
WECOM_WEBHOOK_URL=

SUMMARY_LANGUAGE=English
MAX_INPUT_CHARS=45000

# IMA human downloader. This avoids IMA OpenAPI and uses a persistent
# Chromium profile on the VPS. Run `ima-research-bot ima-human-login`
# once through Xvfb/noVNC to complete Tencent/QQ/WeChat login.
IMA_HUMAN_URL=https://ima.qq.com
IMA_HUMAN_CDP_URL=
IMA_HUMAN_PROFILE_DIR=/opt/ima-browser-profile
IMA_HUMAN_DOWNLOAD_DIR=/opt/research-inbox
IMA_HUMAN_MAX_DOWNLOADS_PER_CYCLE=3
IMA_HUMAN_POLL_INTERVAL_MINUTES=10
IMA_HUMAN_HEADLESS=1
# One or more IMA UI paths. Separate levels with | and separate paths with ;;.
# Tokens: LATEST_MONTH opens the newest visible month folder; LATEST_DAY opens
# the newest visible day folder. LATEST_SCOPE keeps opening the newest
# date/month folder it can see, which is better for uneven folder structures.
IMA_HUMAN_FOLDER_PATHS=【爱分享】盈策系列|六、高盛、花旗、瑞银、摩根等外资研报🌏|LATEST_SCOPE;;【爱分享】盈策系列|七、中金、中信、华泰等内资研报🌈|LATEST_SCOPE;;【爱分享】盈策系列|五、调研会议纪要📅|LATEST_SCOPE;;【爱分享】盈策系列|四、红宝书🏆|LATEST_SCOPE
IMA_HUMAN_LATEST_SCOPE_DEPTH=4
IMA_HUMAN_LATEST_VISIBLE_FILES_ONLY=1
