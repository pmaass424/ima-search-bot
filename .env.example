STATE_DB=./state/research_bot.sqlite3
OUTPUT_DIR=./out
POLL_INTERVAL_MINUTES=15
PROCESS_LIMIT_PER_RUN=3
RECENT_MEMORY_LIMIT=20
BATCH_INSIGHTS_ENABLED=1
DIGEST_MODE=1

# Cloudflare R2 canonical storage.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=research-storage
R2_ENDPOINT=
R2_PREFIX=research
R2_CACHE_DIR=./out/r2-cache
R2_MAX_ITEMS=200
R2_MAX_DOWNLOADS_PER_RUN=3
R2_LATEST_ONLY=1
R2_TARGET_DAYS_AGO=
R2_TARGET_REPORT_DATE=
R2_TARGET_UTC_OFFSET_HOURS=8

# Upload local baseline folder to R2. Keep 0 for no limit.
STORAGE_UPLOAD_LIMIT=0

# IMA / Tencent OpenAPI. This is the only IMA collector path.
IMA_CLIENT_ID=
IMA_API_KEY=
IMA_BASE_URL=https://ima.qq.com
IMA_KNOWLEDGE_BASE_ID=
IMA_FOLDER_ID=
IMA_MAX_PAGES=1
IMA_MAX_ITEMS=10
IMA_MAX_DOWNLOADS_PER_RUN=1
IMA_R2_MAX_UPLOADS=1
IMA_LATEST_DATE_FOLDER=1
IMA_LATEST_DATE_FOLDER_DEPTH=4
IMA_RECURSIVE=1
IMA_LATEST_ONLY=1
IMA_TARGET_DAYS_AGO=0
IMA_TARGET_REPORT_DATE=
IMA_TARGET_UTC_OFFSET_HOURS=8

# OpenAI summarizer.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_DAILY_BUDGET_USD=5
OPENAI_TEXT_INPUT_USD_PER_1M=0.40
OPENAI_TEXT_OUTPUT_USD_PER_1M=1.60
OPENAI_TTS_USD_PER_1K_CHARS=0.03

# Audio.
TTS_PROVIDER=openai
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Telegram / WeCom delivery.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SEND_TEXT_UPDATES=1
WECOM_WEBHOOK_URL=

SUMMARY_LANGUAGE=English
MAX_INPUT_CHARS=45000

# Runtime switches.
COLLECTOR_ENABLED=1
TELEGRAM_COMMANDS_ENABLED=1
IMA_CHAT_ENABLED=0
